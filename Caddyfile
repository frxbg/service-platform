{
  admin off
  local_certs
  auto_https disable_redirects
}

https://localhost, https://127.0.0.1 {
  tls internal
  reverse_proxy frontend:3000
}

https://{$PUBLIC_HOST:localhost} {
  tls internal
  reverse_proxy frontend:3000
}

